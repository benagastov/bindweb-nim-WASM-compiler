# =============================================================================
# versions.env — single source of truth for every upstream pin.
# Sourced by all build.sh scripts and read by CI. Change here, rebuild,
# and every artifact is reproducible from these exact commits.
# =============================================================================

# ---- LLVM / Clang / LLD (the in-browser C/C++ compiler) ---------------------
# binji's LLVM fork carries the patches that let clang/lld compile to wasm32-wasi
# and talk to the in-memory filesystem (memfs). We pin the exact commit so the
# build is reproducible and so the LLVM *source* is what users hack on.
#   https://github.com/binji/llvm-project   (branch: master)
LLVM_REPO="https://github.com/binji/llvm-project"
LLVM_REF="5dc09c94393510bc8d042a9f07382b53e845c0f2"
# clang's resource-dir version string baked into this LLVM (used by sysroot.tar
# layout and by the IDE's clang launch args). binji's fork is LLVM 8.0.1-era.
LLVM_RESOURCE_VER="8.0.1"

# ---- wasi-sdk (provides the wasm sysroot + a clang that targets wasm) --------
# Used as the *cross toolchain* to compile LLVM and memfs to wasm32-wasi.
# wasi-sdk-12 is the last series whose wasi-libc still exposes <wasi/core.h>,
# which binji's memfs.c includes. If you port memfs.c to the modern
# <wasi/api.h>, bump this to wasi-sdk-24 (also pinned below) and set
# MEMFS_WASI_API=modern in toolchain/memfs/build.sh.
WASI_SDK_REPO="https://github.com/WebAssembly/wasi-sdk"
WASI_SDK_REF_LEGACY="db1b572d4b55e8d8cbc5cc7f950246efa6f55ed2"   # wasi-sdk-12
WASI_SDK_REF_MODERN="a6f46397e473699e9f29c878fd563f532e7c0e3c"   # wasi-sdk-24
WASI_SDK_REF="${WASI_SDK_REF_LEGACY}"
WASI_SDK_VERSION_LEGACY="12.0"
WASI_SDK_VERSION_MODERN="24.0"

# ---- Nim (the compiler we cross-compile to wasm for the in-browser IDE) ------
#   https://github.com/nim-lang/Nim
NIM_REPO="https://github.com/nim-lang/Nim"
NIM_REF="cdaaef08b0ad189e21cdd09a4c861306ec22d4e4"             # v2.0.14
NIM_VERSION="2.0.14"
# Nim 2.0 moved some stdlib into split repos; pin the ones the compiler needs.
NIM_CHECKSUMS_REPO="https://github.com/nim-lang/checksums"
NIM_CHECKSUMS_REF="HEAD"
NIM_CSOURCES_REPO="https://github.com/nim-lang/csources_v2"
NIM_CSOURCES_REF="HEAD"

# ---- Emscripten (used to emit nim.wasm + nim-bundle.js, matching upstream) ---
#   https://github.com/emscripten-core/emsdk
# The existing nim-bundle.js is an Emscripten module; we reproduce it from
# source with a pinned emsdk so the JS glue stays byte-compatible in shape.
EMSDK_REPO="https://github.com/emscripten-core/emsdk"
EMSDK_REF="a36df02dc438e8b02f91122a4c62eeecb6784272"           # 3.1.69
EMSDK_VERSION="3.1.69"

# ---- Output layout ----------------------------------------------------------
# Where finished artifacts land. The IDE consumes from here.
DIST_CLANG_DIR="bindweb-nim-browser/static/clang"   # clang.wasm lld.wasm memfs.wasm sysroot.tar
DIST_NIM_DIR="bindweb-nim-browser/static/nim"       # nim.wasm nim-bundle.js nimbase.h
